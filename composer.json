{
    "name": "david-oghi/certificate-generation",
    "version": "1.0.0",
    "description": "A reusable Laravel certificate template designer, renderer, issuer, verifier and download package.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-gd": "*",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/validation": "^10.0|^11.0|^12.0|^13.0",
        "dompdf/dompdf": "^3.0",
        "intervention/image": "^2.7",
        "simplesoftwareio/simple-qrcode": "^4.2"
    },
    "autoload": {
        "psr-4": {
            "DavidOghi\\CertificateGeneration\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DavidOghi\\CertificateGeneration\\CertificateServiceProvider"
            ]
        },
        "davsong": {
            "origin_application": {
                "name": "Oakland",
                "repository": "https://github.com/davsong01/oakland.git",
                "local_path": "/Applications/MAMP/htdocs/oakland",
                "package_source_path": "/Applications/MAMP/htdocs/oakland/packages/david-oghi/certificate-generation",
                "note": "This package was first extracted from the Oakland certificate designer implementation."
            },
            "test_application": {
                "name": "Oakland",
                "repository": "https://github.com/davsong01/oakland.git",
                "local_path": "/Applications/MAMP/htdocs/oakland",
                "package_source_path": "/Applications/MAMP/htdocs/oakland/packages/david-oghi/certificate-generation",
                "note": "Use this Laravel app as the living integration test project before publishing package updates."
            }
        },
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
